<Window x:Class="Nottext_Data_Protector.Views.AppMessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Mensagem" Width="500"
        MinWidth="440" MaxWidth="620" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" Background="Transparent" AllowsTransparency="True"
        Foreground="{DynamicResource TextPrimaryBrush}">

    <Grid Background="Transparent">
        <Border Margin="14" Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource WindowOutlineBrush}" BorderThickness="1" CornerRadius="18">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24" ShadowDepth="0" Opacity="0.28"/>
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,0,1" CornerRadius="18,18,0,0" MouseLeftButtonDown="ChromeTitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0,10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="28" Height="28" CornerRadius="10" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center">
                        <TextBlock Text="N" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock x:Name="CaptionText" Grid.Column="1" Text="Mensagem" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0" TextTrimming="CharacterEllipsis"/>
                    <Button Grid.Column="2" Style="{StaticResource ChromeCloseButton}" Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="54" Height="54" CornerRadius="18" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Top" Margin="0,2,18,0">
                    <Path x:Name="IconPath" Width="25" Height="25" Stretch="Uniform" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M11,17 L13,17 L13,11 L11,11 Z M11,9 L13,9 L13,7 L11,7 Z M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z"/>
                </Border>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" Text="Mensagem" FontSize="20" FontWeight="Bold" TextWrapping="Wrap" Margin="0,0,0,8"/>
                    <TextBlock x:Name="MessageText" Text="Conteúdo" Style="{StaticResource MutedText}" FontSize="14" TextWrapping="Wrap" MaxHeight="260"/>

                    <StackPanel x:Name="ButtonsPanel" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,22,0,0">
                        <Button x:Name="CancelButton" Content="Cancelar" Style="{StaticResource GhostButton}" Click="CancelButton_Click" Margin="0,0,10,0" Visibility="Collapsed"/>
                        <Button x:Name="OkButton" Content="OK" Style="{StaticResource PrimaryButton}" Click="OkButton_Click" MinWidth="96"/>
                    </StackPanel>
                </StackPanel>
            </Grid>
        </Grid>
        </Border>
    </Grid>
</Window>
