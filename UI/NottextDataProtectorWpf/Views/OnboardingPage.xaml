<Page x:Class="Nottext_Data_Protector.Views.OnboardingPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <Grid>
        <Border Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="28"
                Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel>
                    <Border Width="64" Height="64" HorizontalAlignment="Left" CornerRadius="20" Background="{DynamicResource AccentSoftBrush}">
                        <TextBlock Text="N" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="28" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}"/>
                    </Border>
                    <TextBlock x:Name="StepTitle" Text="Bem-vindo ao Nottext Data Protector" FontSize="30" FontWeight="Bold" Margin="0,20,0,0"/>
                    <TextBlock x:Name="StepSubtitle" Text="Proteja arquivos, pastas e processos importantes com uma experiência simples e direta." Style="{StaticResource MutedText}" FontSize="15" TextWrapping="Wrap" Margin="0,8,0,0"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" Margin="0,20,0,20" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <Grid>
                    <Grid x:Name="WelcomeStep">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource Card}" Padding="22" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock Text="Controle centralizado" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Gerencie objetos protegidos, processos autorizados e configurações em uma única interface." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="22" Margin="10,0,0,0">
                            <StackPanel>
                                <TextBlock Text="Proteção com clareza" FontSize="18" FontWeight="Bold"/>
                                <TextBlock Text="Acompanhe o status do driver e da proteção logo na tela principal, sem procurar menus escondidos." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="ProtectionsStep" Visibility="Collapsed">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <Border Style="{StaticResource Card}" Padding="16" Margin="0,0,8,8">
                            <StackPanel>
                                <TextBlock Text="Proteger Arquivo" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Impede alterações indesejadas em arquivos importantes, ajudando a preservar dados sensíveis." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Padding="16" Margin="8,0,0,8">
                            <StackPanel>
                                <TextBlock Text="Proteger Pasta" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Aplica a proteção em diretórios inteiros, ideal para conjuntos de documentos ou arquivos do sistema." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="16" Margin="0,8,8,0">
                            <StackPanel>
                                <TextBlock Text="Processos Autorizados" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Define quais processos podem operar dentro das regras configuradas, reduzindo ações inesperadas." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource Card}" Padding="16" Margin="8,8,0,0">
                            <StackPanel>
                                <TextBlock Text="Proteção Global" FontSize="16" FontWeight="Bold"/>
                                <TextBlock Text="Liga ou desliga o comportamento geral de proteção quando você precisar alternar rapidamente." Style="{StaticResource MutedText}" TextWrapping="Wrap" Margin="0,5,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <Grid x:Name="StartStep" Visibility="Collapsed">
                        <Border Style="{StaticResource Card}" Padding="28" HorizontalAlignment="Stretch" VerticalAlignment="Center">
                            <StackPanel HorizontalAlignment="Center" MaxWidth="620">
                                <TextBlock Text="Tudo pronto para iniciar" FontSize="26" FontWeight="Bold" TextAlignment="Center"/>
                                <TextBlock Text="Depois de iniciar, você poderá instalar os componentes necessários, escolher o tema, configurar objetos protegidos e exportar suas configurações quando quiser." Style="{StaticResource MutedText}" FontSize="15" TextWrapping="Wrap" TextAlignment="Center" Margin="0,12,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                    </Grid>
                </ScrollViewer>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Ellipse x:Name="Dot1" Width="8" Height="8" Fill="{DynamicResource AccentBrush}" Margin="0,0,7,0"/>
                        <Ellipse x:Name="Dot2" Width="8" Height="8" Fill="{DynamicResource BorderBrushSoft}" Margin="0,0,7,0"/>
                        <Ellipse x:Name="Dot3" Width="8" Height="8" Fill="{DynamicResource BorderBrushSoft}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button x:Name="BackButton" Content="Voltar" Style="{StaticResource GhostButton}" Visibility="Collapsed" Click="BackButton_Click" Margin="0,0,10,0"/>
                        <Button x:Name="NextButton" Content="Próximo" Style="{StaticResource PrimaryButton}" Click="NextButton_Click"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>
    </Grid>
</Page>
