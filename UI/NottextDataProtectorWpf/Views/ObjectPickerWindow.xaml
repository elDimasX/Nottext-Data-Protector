<Window x:Class="Nottext_Data_Protector.Views.ObjectPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Procurar arquivo ou objeto" Height="620" Width="820"
        MinHeight="520" MinWidth="720"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResize"
        WindowStyle="None" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextPrimaryBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource WindowOutlineBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="44"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,0,1" MouseLeftButtonDown="ChromeTitleBar_MouseLeftButtonDown">
            <Grid Margin="14,0,10,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Width="28" Height="28" CornerRadius="10" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center"><TextBlock Text="N" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <TextBlock Grid.Column="1" Text="Procurar arquivo ou objeto" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="—" Style="{StaticResource ChromeButton}" Click="ChromeMinimizeButton_Click"/>
                    <Button x:Name="ChromeMaximizeButton" Style="{StaticResource ChromeButton}" Click="ChromeMaximizeButton_Click" ToolTip="Maximizar ou restaurar">
                        <Path x:Name="ChromeMaximizeIcon" Width="12" Height="12" Stretch="Uniform" Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" StrokeThickness="1.8" Fill="Transparent" Data="M3,3 L21,3 L21,21 L3,21 Z"/>
                    </Button>
                    <Button Style="{StaticResource ChromeCloseButton}" Click="ChromeCloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
            <Grid Grid.Row="1">
                <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}" Padding="18" Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Width="38" Height="38" CornerRadius="14" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Top">
                    <Path Width="20" Height="20" Stretch="Uniform" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"
                          Data="M3,5 L9,5 L11,7 L21,7 L21,18 L3,18 Z M5,9 L5,16 L19,16 L19,9 Z"/>
                </Border>
                <StackPanel Grid.Column="1" Margin="12,0,0,0">
                    <TextBlock Text="Selecione o arquivo ou pasta" FontSize="24" FontWeight="Bold"/>
                    <TextBlock Text="Navegue pelas pastas e escolha um arquivo ou diretório para proteger." Style="{StaticResource MutedText}" Margin="0,5,0,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="0,0,0,14">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <Button Content="Voltar" Style="{StaticResource GhostButton}" Click="BackButton_Click" Margin="0,0,10,0"/>
            <TextBox x:Name="CurrentPathBox" Grid.Column="1" KeyDown="CurrentPathBox_KeyDown"/>
            <Button Grid.Column="2" Content="Ir" Style="{StaticResource GhostButton}" Click="GoButton_Click" Margin="10,0,0,0"/>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource Card}" Padding="12">
            <Grid>
                <TextBlock x:Name="EmptyText" Text="Nenhum item encontrado nesta pasta." Style="{StaticResource MutedText}" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                <ListView x:Name="ItemsList" MouseDoubleClick="ItemsList_MouseDoubleClick" SelectionChanged="ItemsList_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Border Background="{DynamicResource CardItemBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="16" Padding="14" Margin="0,0,0,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="42"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="32" Height="32" CornerRadius="11" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center">
                                        <Path Width="18" Height="18" Stretch="Uniform" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="{Binding IconData}"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" Margin="12,0,14,0" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding FullPath}" Style="{StaticResource MutedText}" FontSize="12" TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                                    </StackPanel>
                                    <Border Grid.Column="2" Background="{DynamicResource FieldBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="12" Padding="10,5" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Kind}" Foreground="{DynamicResource AccentBrush}" FontSize="12" FontWeight="SemiBold"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <TextBlock x:Name="SelectedPathText" Text="Nenhum objeto selecionado." Style="{StaticResource MutedText}" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancelar" Style="{StaticResource GhostButton}" Click="CancelButton_Click" Margin="0,0,10,0"/>
                <Button x:Name="SelectButton" Content="Selecionar objeto" Style="{StaticResource PrimaryButton}" Click="SelectButton_Click" IsEnabled="False"/>
            </StackPanel>
        </Grid>
    </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>