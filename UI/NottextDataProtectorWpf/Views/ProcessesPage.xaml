<Page x:Class="Nottext_Data_Protector.Views.ProcessesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" AllowDrop="True" Drop="Page_Drop" DragEnter="Page_DragEnter">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Lista de processos" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Adicione executáveis que devem ser reconhecidos pelo arquivo de processos do driver." Style="{StaticResource MutedText}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Adicionar processo" Style="{StaticResource PrimaryButton}" Click="AddButton_Click" Margin="0,0,10,0"/>
                    <Button Content="Remover" Style="{StaticResource GhostButton}" Click="RemoveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <Border BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Background="{DynamicResource PanelBrush}" Padding="16">
                <Grid>
                    <TextBlock x:Name="EmptyText"
                               Text="Nenhum processo cadastrado ainda. Arraste um .exe para cá."
                               Style="{StaticResource MutedText}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="16"/>
                    <ListView x:Name="EntriesList"
                              ItemsSource="{Binding Entries}"
                              SelectionMode="Extended">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource CardItemBrush}"
                                        BorderBrush="{DynamicResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        CornerRadius="18"
                                        Padding="16"
                                        Margin="0,0,0,2">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="44"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Width="34" Height="34" CornerRadius="12" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center">
                                            <Path Width="17" Height="17" Stretch="Uniform" Fill="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" VerticalAlignment="Center" Data="M8,5 L16,5 L16,12 L8,12 Z M5,21 L7,15 L17,15 L19,21 Z"/>
                                        </Border>

                                        <StackPanel Grid.Column="1" Margin="12,0,18,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Path}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="Executável monitorado" Style="{StaticResource MutedText}" FontSize="12" Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Border Grid.Column="2"
                                                Background="{DynamicResource FieldBrush}"
                                                BorderBrush="{DynamicResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="13"
                                                Padding="12,6"
                                                VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Protection}" Foreground="{DynamicResource SuccessBrush}" FontWeight="SemiBold" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource FooterBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,18,0,0">
            <Grid>
                <TextBlock Text="Esses processos continuam sendo salvos no mesmo arquivo original." Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancelar" Style="{StaticResource GhostButton}" Click="CancelButton_Click" IsEnabled="False" Margin="0,0,10,0"/>
                    <Button x:Name="SaveButton" Content="Salvar alterações" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
