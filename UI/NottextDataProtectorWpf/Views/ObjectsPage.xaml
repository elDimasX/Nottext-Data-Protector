<Page x:Class="Nottext_Data_Protector.Views.ObjectsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent" AllowDrop="True" Drop="Page_Drop" DragEnter="Page_DragEnter">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource Card}" Margin="0,0,0,18">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Arquivos, pastas e executáveis" FontSize="20" FontWeight="Bold"/>
                    <TextBlock Text="Use o botão adicionar ou arraste itens para a tela. Depois escolha o tipo de proteção e salve." Style="{StaticResource MutedText}" Margin="0,6,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="Adicionar" Style="{StaticResource PrimaryButton}" Click="AddButton_Click" Margin="0,0,10,0"/>
                    <Button Content="Remover" Style="{StaticResource GhostButton}" Click="RemoveButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource Card}" Padding="12">
            <Grid>
                <Border BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="20" Background="{DynamicResource PanelBrush}" Padding="16">
                    <Grid>
                        <TextBlock x:Name="EmptyText"
                                   Text="Nenhum objeto protegido ainda. Arraste arquivos para cá para começar."
                                   Style="{StaticResource MutedText}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   FontSize="16"/>
                        <ListView x:Name="EntriesList"
                                  ItemsSource="{Binding Entries}"
                                  SelectionMode="Extended"
                                  MouseDoubleClick="EntriesList_MouseDoubleClick"
                                  SelectionChanged="EntriesList_SelectionChanged">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{DynamicResource CardItemBrush}"
                                            BorderBrush="{DynamicResource BorderBrushSoft}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="16"
                                            Margin="0,0,0,2">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="44"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Width="34" Height="34" CornerRadius="12" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center">
                                                <Path Width="19" Height="19" Stretch="Uniform" Fill="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                      Data="M3,5 L9,5 L11,7 L21,7 L21,18 L3,18 Z M5,9 L5,16 L19,16 L19,9 Z"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="12,0,18,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Path}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="Objeto protegido" Style="{StaticResource MutedText}" FontSize="12" Margin="0,4,0,0"/>
                                            </StackPanel>

                                            <Border Grid.Column="2"
                                                    Background="{DynamicResource FieldBrush}"
                                                    BorderBrush="{DynamicResource BorderBrushSoft}"
                                                    BorderThickness="1"
                                                    CornerRadius="13"
                                                    Padding="12,6"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Protection}" Foreground="{DynamicResource AccentBrush}" FontWeight="SemiBold" FontSize="12"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="{DynamicResource FooterBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="18" Padding="14" Margin="0,18,0,0">
            <Grid>
                <TextBlock Text="Dica: duplo clique em um item para alterar o tipo de proteção." Style="{StaticResource MutedText}" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="CancelButton" Content="Cancelar" Style="{StaticResource GhostButton}" Click="CancelButton_Click" IsEnabled="False" Margin="0,0,10,0"/>
                    <Button x:Name="SaveButton" Content="Salvar alterações" Style="{StaticResource PrimaryButton}" Click="SaveButton_Click" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
