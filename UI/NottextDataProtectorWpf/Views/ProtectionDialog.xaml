<Window x:Class="Nottext_Data_Protector.Views.ProtectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Definir proteção" Height="580" Width="800"
        
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        WindowStyle="None" Background="{DynamicResource BgBrush}" Foreground="{DynamicResource TextPrimaryBrush}">
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="8"
                            GlassFrameThickness="0"
                            CornerRadius="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>
    <Border Background="{DynamicResource BgBrush}" BorderBrush="{DynamicResource WindowOutlineBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions><RowDefinition Height="44"/><RowDefinition Height="*"/></Grid.RowDefinitions>
            <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="0,0,0,1" MouseLeftButtonDown="ChromeTitleBar_MouseLeftButtonDown">
            <Grid Margin="14,0,10,0">
                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                <Border Width="28" Height="28" CornerRadius="10" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center"><TextBlock Text="N" Foreground="{DynamicResource AccentBrush}" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/></Border>
                <TextBlock Grid.Column="1" Text="Definir proteção" Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold" VerticalAlignment="Center" Margin="10,0,0,0"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="—" Style="{StaticResource ChromeButton}" Click="ChromeMinimizeButton_Click"/>
                    
                    <Button Style="{StaticResource ChromeCloseButton}" Click="ChromeCloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Border>
            <Grid Grid.Row="1">
                <Grid Margin="24,22,24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Definir proteção" FontSize="26" FontWeight="Bold"/>
            <TextBlock Text="Escolha como esse objeto será tratado pelo driver." Style="{StaticResource MutedText}" Margin="0,6,0,18"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Margin="0,0,0,14">
            <TextBlock Text="Caminho" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBox x:Name="PathTextBox"/>
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Tipo de proteção" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <UniformGrid x:Name="ProtectionOptionsPanel" Columns="2" Margin="0,0,0,2">
                <RadioButton x:Name="ReadOnlyRadio" Tag="Somente Leitura" Style="{StaticResource ProtectionOptionRadio}" Checked="ProtectionOption_Checked">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Margin="0,0,10,0" Data="M6,2 L16,2 L20,6 L20,22 L6,22 Z M15,3.5 L15,7 L18.5,7 M9,12 L17,12 M9,16 L15,16"/>
                        <TextBlock Text="Somente Leitura" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="BlockRadio" Tag="Bloquear" Style="{StaticResource ProtectionOptionRadio}" Checked="ProtectionOption_Checked">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Margin="0,0,10,0" Data="M7,10 L7,6 L17,6 L17,10 L19,10 L19,21 L5,21 L5,10 Z M9,10 L15,10 L15,8 L9,8 Z"/>
                        <TextBlock Text="Bloquear" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="HideRadio" Tag="Ocultar" Style="{StaticResource ProtectionOptionRadio}" Checked="ProtectionOption_Checked">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Margin="0,0,10,0" Data="M2,12 L6,8 L12,6 L18,8 L22,12 L18,16 L12,18 L6,16 Z M10,10 L14,10 L14,14 L10,14 Z M4,21 L21,4"/>
                        <TextBlock Text="Ocultar" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="NoExecuteRadio" Tag="Não Executar" Style="{StaticResource ProtectionOptionRadio}" Checked="ProtectionOption_Checked">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Margin="0,0,10,0" Data="M8,5 L19,12 L8,19 Z M4,4 L20,20 L19,21 L3,5 Z"/>
                        <TextBlock Text="Não Executar" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    </StackPanel>
                </RadioButton>
                <RadioButton x:Name="ProtectProcessRadio" Tag="Proteger Processo" Style="{StaticResource ProtectionOptionRadio}" Checked="ProtectionOption_Checked">
                    <StackPanel Orientation="Horizontal">
                        <Path Width="17" Height="17" Stretch="Uniform" Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}" Margin="0,0,10,0" Data="M12,2 L20,5 L20,12 L17,18 L12,22 L7,18 L4,12 L4,5 Z M9,8 L15,8 L15,13 L9,13 Z M7,18 L9,15 L15,15 L17,18 Z"/>
                        <TextBlock Text="Proteger Processo" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=RadioButton}}"/>
                    </StackPanel>
                </RadioButton>
            </UniformGrid>
        </StackPanel>

        <Border Grid.Row="3" Background="{DynamicResource PanelBrush}" BorderBrush="{DynamicResource BorderBrushSoft}" BorderThickness="1" CornerRadius="14" Padding="10,8" Margin="0,10,0,0" MinHeight="44" MaxHeight="64">
            <TextBlock x:Name="DescriptionText" Style="{StaticResource MutedText}"/>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancelar" Style="{StaticResource GhostButton}" Click="CancelButton_Click" Margin="0,0,10,0"/>
            <Button Content="Confirmar" Style="{StaticResource PrimaryButton}" Click="ConfirmButton_Click"/>
        </StackPanel>
    </Grid>
            </Grid>
        </Grid>
    </Border>
</Window>