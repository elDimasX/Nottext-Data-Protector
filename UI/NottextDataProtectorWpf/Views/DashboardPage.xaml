<Page x:Class="Nottext_Data_Protector.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="Transparent">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Style="{StaticResource Card}" Margin="0,0,0,18" Padding="30">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock x:Name="DashboardTitleText" Text="Primeira instalação" FontSize="30" FontWeight="Bold"/>
                        <TextBlock x:Name="DashboardSubtitleText" Text="O driver WlfS ainda não está instalado. Instale os componentes para ativar a proteção e liberar as demais configurações." Style="{StaticResource MutedText}" FontSize="16" Margin="0,8,0,0"/>
                        <StackPanel Orientation="Horizontal" Margin="0,22,0,0">
                            <Button x:Name="InstallButton" Content="Instalar componentes" Style="{StaticResource PrimaryButton}" Click="InstallButton_Click" Margin="0,0,10,0"/>
                            <Button Content="Verificar novamente" Style="{StaticResource GhostButton}" Click="RefreshButton_Click"/>
                        </StackPanel>
                    </StackPanel>
                    <Border Grid.Column="1" Width="96" Height="96" CornerRadius="32" Background="{DynamicResource AccentSoftBrush}" VerticalAlignment="Center" Margin="24,0,0,0">
                        <TextBlock Text="N" FontSize="46" FontWeight="Bold" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,18">
                <Border Style="{StaticResource Card}" Margin="0,0,9,0">
                    <StackPanel>
                        <TextBlock Text="Driver" Style="{StaticResource MutedText}"/>
                        <TextBlock x:Name="DriverStatusText" Text="Não instalado" FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="9,0,9,0">
                    <StackPanel>
                        <TextBlock Text="Proteção" Style="{StaticResource MutedText}"/>
                        <TextBlock x:Name="ProtectionSummaryText" Text="Aguardando instalação" FontSize="22" FontWeight="Bold" Margin="0,6,0,0"/>
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource Card}" Margin="9,0,0,0">
                    <StackPanel>
                        <TextBlock x:Name="NextStepLabelText" Text="Próximo passo" Style="{StaticResource MutedText}"/>
                        <TextBlock x:Name="NextStepValueText" Text="Reiniciar se necessário" FontSize="22" FontWeight="Bold" Margin="0,6,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <Border Grid.Row="2" Style="{StaticResource Card}">
                <StackPanel>
                    <TextBlock x:Name="DetailsTitleText" Text="O que acontece agora?" FontSize="22" FontWeight="Bold"/>
                    <TextBlock x:Name="DetailsBodyText" Text="O aplicativo vai solicitar permissão de administrador, instalar os arquivos do driver e ajustar o serviço WlfS. Depois disso, talvez seja necessário reiniciar o Windows para completar o modo de teste e iniciar o driver corretamente." Style="{StaticResource MutedText}" FontSize="15" Margin="0,8,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </ScrollViewer>
</Page>
